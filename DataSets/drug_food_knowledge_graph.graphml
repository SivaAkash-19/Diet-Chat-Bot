    <edge source="Sulopenem etzadroxil" target="Take with food. The absorption of sulopenem is improved when administered with a meal.">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Mobocertinib" target="Avoid St. John's Wort. St. John's Wort is a potent CYP3A inducer and may decrease the efficacy of mobocertinib.">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Mobocertinib" target="Take with or without food. Co-administration with food does not significantly affect the disposition of mobocertinib.">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Serdexmethylphenidate" target="Take with or without food. Food does not exert a clinically meaningful effect on dexmethylphenidate exposure">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Serdexmethylphenidate" target="though it does lengthen the time to reach maximum plasma concentration from two hours to approximately 4-4.5 hours.">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Deucravacitinib" target="Take with or without food. Food has no clinically significant effect on drug absorption and exposure.">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Nirmatrelvir" target="Avoid St. John's Wort. Co-administration may reduce serum concentrations of niramtrelvir and interfere with virologic efficacy.">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Nirmatrelvir" target="Take with or without food. Co-administration of nirmatrelvir with food does not significantly alter its pharmacokinetics.">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Insulin icodec" target="Take with or without food. Insulin icodec is a long-acting insulin and therefore does not need to be administered with respect to food.">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Belumosudil" target="Take at the same time every day. Belumosudil should be taken with a meal at approximately the same time each day.">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Belumosudil" target="Take with food. The co-administration of food increases the absorption of belumosudil.">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Fidanacogene elaparvovec" target="Avoid excessive or chronic alcohol consumption. Alcohol may reduce drug efficacy and increase the risk of serious hepatic reactions following drug administration.">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Repotrectinib" target="Take with or without food. Take repotrectinib at about the same time each day with or without food.">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Linzagolix" target="Take with or without food. The co-administration of linzagolix with food does not effect its pharmacokinetics to a clinically significant extent.">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Vorasidenib" target="Take with or without food. A high-fat and high-calorie increases vorasidenib and Cmax">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Pirtobrutinib" target="Take at the same time every day. Pirtobrutinib should be taken at approximately the same time each day with or without food.">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Pirtobrutinib" target="Take with or without food. High-fat">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Pirtobrutinib" target="high-calorie meals do not have a clinically significant effect in the pharmacokinetics of pirtobrutinib.">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Fecal microbiota" target="Take on an empty stomach. For the oral administration of fecal microbiota spore capsules">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Fecal microbiota" target="each dose should be taken on an empty stomach prior to the first meal of the day.">
      <data key="d1">interacts_with</data>
    </edge>
    <edge source="Revumenib" target="Take on an empty stomach. Prescribing information for revumenib recommends administration on an empty stomach or with a small">
