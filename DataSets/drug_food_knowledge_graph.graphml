    <node id="Avoid St. John's Wort. St. John's Wort is a potent CYP3A inducer and may decrease the efficacy of mobocertinib.">
      <data key="d0">food</data>
    </node>
    <node id="Take with or without food. Co-administration with food does not significantly affect the disposition of mobocertinib.">
      <data key="d0">food</data>
    </node>
    <node id="Serdexmethylphenidate">
      <data key="d0">drug</data>
    </node>
    <node id="Take with or without food. Food does not exert a clinically meaningful effect on dexmethylphenidate exposure">
      <data key="d0">food</data>
    </node>
    <node id="though it does lengthen the time to reach maximum plasma concentration from two hours to approximately 4-4.5 hours.">
      <data key="d0">food</data>
    </node>
    <node id="Deucravacitinib">
      <data key="d0">drug</data>
    </node>
    <node id="Take with or without food. Food has no clinically significant effect on drug absorption and exposure.">
      <data key="d0">food</data>
    </node>
    <node id="Nirmatrelvir">
      <data key="d0">drug</data>
    </node>
    <node id="Avoid St. John's Wort. Co-administration may reduce serum concentrations of niramtrelvir and interfere with virologic efficacy.">
      <data key="d0">food</data>
    </node>
    <node id="Take with or without food. Co-administration of nirmatrelvir with food does not significantly alter its pharmacokinetics.">
      <data key="d0">food</data>
    </node>
    <node id="Insulin icodec">
      <data key="d0">drug</data>
    </node>
    <node id="Take with or without food. Insulin icodec is a long-acting insulin and therefore does not need to be administered with respect to food.">
      <data key="d0">food</data>
    </node>
    <node id="Belumosudil">
      <data key="d0">drug</data>
    </node>
    <node id="Take at the same time every day. Belumosudil should be taken with a meal at approximately the same time each day.">
      <data key="d0">food</data>
    </node>
    <node id="Take with food. The co-administration of food increases the absorption of belumosudil.">
      <data key="d0">food</data>
    </node>
    <node id="Fidanacogene elaparvovec">
      <data key="d0">drug</data>
    </node>
    <node id="Avoid excessive or chronic alcohol consumption. Alcohol may reduce drug efficacy and increase the risk of serious hepatic reactions following drug administration.">
      <data key="d0">food</data>
    </node>
    <node id="Repotrectinib">
      <data key="d0">drug</data>
    </node>
    <node id="Take with or without food. Take repotrectinib at about the same time each day with or without food.">
      <data key="d0">food</data>
    </node>
    <node id="L-Acetylleucine">
      <data key="d0">drug</data>
    </node>
    <node id="Linzagolix">
      <data key="d0">drug</data>
    </node>
    <node id="Take with or without food. The co-administration of linzagolix with food does not effect its pharmacokinetics to a clinically significant extent.">
      <data key="d0">food</data>
    </node>
    <node id="Vorasidenib">
      <data key="d0">drug</data>
    </node>
    <node id="Take with or without food. A high-fat and high-calorie increases vorasidenib and Cmax">
      <data key="d0">food</data>
    </node>
    <node id="Pirtobrutinib">
      <data key="d0">drug</data>
    </node>
    <node id="Take at the same time every day. Pirtobrutinib should be taken at approximately the same time each day with or without food.">
      <data key="d0">food</data>
    </node>
    <node id="Take with or without food. High-fat">
      <data key="d0">food</data>
    </node>
    <node id="high-calorie meals do not have a clinically significant effect in the pharmacokinetics of pirtobrutinib.">
      <data key="d0">food</data>
    </node>
    <node id="Fecal microbiota">
      <data key="d0">drug</data>
    </node>
    <node id="Take on an empty stomach. For the oral administration of fecal microbiota spore capsules">
      <data key="d0">food</data>
    </node>
    <node id="each dose should be taken on an empty stomach prior to the first meal of the day.">
      <data key="d0">food</data>
    </node>
    <node id="Revumenib">
      <data key="d0">drug</data>
    </node>
    <node id="Take on an empty stomach. Prescribing information for revumenib recommends administration on an empty stomach or with a small">
      <data key="d0">food</data>
    </node>
    <node id="low-fat meal.">
      <data key="d0">food</data>
    </node>
    <node id="Deuruxolitinib">
      <data key="d0">drug</data>
    </node>
    <node id="Take with or without food. Food had negligible effects on deuruxolitinib phramacokinetics.">
      <data key="d0">food</data>
    </node>
    <node id="Benzgalantamine">
      <data key="d0">drug</data>
    </node>
    <node id="Avoid alcohol. The co-administration of benzgalantamine with alcohol may result in dose dumping">
      <data key="d0">food</data>
    </node>
    <node id="although this risk has not been fully characterized in humans.">
      <data key="d0">food</data>
    </node>
    <node id="Take with or without food. Administration with food does not alter pharmacokinetics to a clinically relevant extent.">
      <data key="d0">food</data>
    </node>
